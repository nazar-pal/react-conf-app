{
  "name": "react-conf-app",
  "version": "1.1.3",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "sync-api": "node ./scripts/syncApi.js",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,md}\"",
    "flt": "npm run format && npm run lint && npm run typecheck"
  },
  "dependencies": {
    "@expo/ui": "~55.0.0-preview.4",
    "@expo/vector-icons": "^15.0.3",
    "@shopify/react-native-skia": "2.4.14",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "expo": "55.0.0-preview.8",
    "expo-application": "~55.0.4",
    "expo-constants": "~55.0.3",
    "expo-dev-client": "~55.0.4",
    "expo-device": "~55.0.4",
    "expo-font": "~55.0.3",
    "expo-glass-effect": "~55.0.4",
    "expo-haptics": "~55.0.4",
    "expo-image": "~55.0.3",
    "expo-linear-gradient": "~55.0.4",
    "expo-linking": "~55.0.3",
    "expo-navigation-bar": "~55.0.4",
    "expo-notifications": "~55.0.5",
    "expo-router": "~55.0.0-preview.5",
    "expo-splash-screen": "~55.0.4",
    "expo-status-bar": "~55.0.2",
    "expo-symbols": "~55.0.3",
    "expo-system-ui": "~55.0.4",
    "expo-updates": "~55.0.6",
    "expo-web-browser": "~55.0.4",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.6",
    "react": "19.2.0",
    "react-native": "0.83.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^4.1.1",
    "react-native-nitro-modules": "^0.33.2",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.20.0",
    "react-native-worklets": "0.7.2",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "uniwind": "^1.2.7",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@types/jest": "29.5.14",
    "@types/node": "^25.0.10",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-native": "^5.0.0",
    "knip": "^5.82.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  },
  "trustedDependencies": [
    "@shopify/react-native-skia"
  ],
  "reanimated": {
    "staticFeatureFlags": {
      "DISABLE_COMMIT_PAUSING_MECHANISM": true
    }
  }
}
